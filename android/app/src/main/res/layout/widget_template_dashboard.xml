<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root" android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@drawable/widget_bg" android:orientation="vertical" android:padding="12dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
        <ImageView android:id="@+id/iv_icon" android:layout_width="14dp" android:layout_height="14dp" android:layout_marginEnd="4dp" />
        <TextView android:id="@+id/tv_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.08" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:layout_marginTop="6dp">
        <LinearLayout android:id="@+id/cell1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical">
            <TextView android:id="@+id/cell1_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:text="—" />
            <TextView android:id="@+id/cell1_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#8888AA" android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/cell2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical">
            <TextView android:id="@+id/cell2_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:text="—" />
            <TextView android:id="@+id/cell2_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#8888AA" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <LinearLayout android:id="@+id/cell3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical">
            <TextView android:id="@+id/cell3_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:text="—" />
            <TextView android:id="@+id/cell3_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#8888AA" android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/cell4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:orientation="vertical">
            <TextView android:id="@+id/cell4_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:text="—" />
            <TextView android:id="@+id/cell4_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#8888AA" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
